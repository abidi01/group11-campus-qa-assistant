APP_SECRET=replace-with-a-long-random-string
DATABASE_PATH=./data/campus_qa.db
UPLOAD_DIR=./data/uploads
DATA_DIR=./data
FRONTEND_ORIGIN=http://localhost:5173
# 多来源用逗号分隔，例如：https://www.hhu.edu.cn,https://xxxy.hhu.edu.cn
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5180

# 阿里云 DashScope 配置（必须，Embedding + LLM 共用 DASHSCOPE_API_KEY）
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
EMBEDDING_MODEL=text-embedding-v3
LLM_MODEL=qwen-turbo

# 如需使用 OpenAI 兼容接口，可覆盖下面两项；默认留空则复用 DashScope
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# RAG 参数
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# 网页知识采集使用支持联网抓取的模型
WEB_DOCUMENT_MODEL=qwen3-max
WEB_AI_TIMEOUT_SECONDS=120
